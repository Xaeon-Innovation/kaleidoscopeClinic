# ── Firebase (client) — Auth + Firestore ─────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server) ─────────────────────────────────────────────────
# On Vercel: paste the full service account JSON as one line / multiline secret.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Local dev alternative: path to JSON file in project root.
# FIREBASE_SERVICE_ACCOUNT_PATH=kaleidoscope-clinic-firebase-adminsdk-*.json

# ── Image uploads (Vercel Blob) ───────────────────────────────────────────────
# Create a Blob store in Vercel dashboard → Storage → Blob (auto-adds this token).
BLOB_READ_WRITE_TOKEN=
# blob = Vercel Blob (production). local = public/uploads/ (offline dev only).
CASE_IMAGE_STORAGE=blob

# ── App URL ─────────────────────────────────────────────────────────────────
# Set to https://<project>.vercel.app after first deploy (or your custom domain).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# APP_BASE_URL=

# ── Stripe (booking deposits) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Google Calendar OAuth (admin booking) ─────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://<domain>/api/admin/google/callback

# ── Email (Resend — contact / lead notifications) ─────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@kaleidoscopedental.co.uk
# CONTACT_EMAIL=hello@kaleidoscopedental.co.uk

# ── Booking schedule ──────────────────────────────────────────────────────────
BOOKING_TIMEZONE=Europe/London
BOOKING_OPEN_HOUR=9
BOOKING_CLOSE_HOUR=17
BOOKING_SLOT_MINUTES=45
BOOKING_WEEKDAYS=1,2,3,4,5
BOOKING_DEPOSIT_PENCE=5000
BOOKING_CURRENCY=gbp
BOOKING_HOLD_MINUTES=20
