# Firebase (client — from Firebase Console → Project settings → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) — use a file path (recommended) OR inline JSON on one line
FIREBASE_SERVICE_ACCOUNT_PATH=kaleidoscope-clinic-firebase-adminsdk-fbsvc-cf5e0455fa.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# App URL (production)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Calendar OAuth (clinician personal calendar)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; default is {NEXT_PUBLIC_APP_URL}/api/admin/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=

# Booking defaults (used until saved in Admin → Settings; per-day hours are editable there)
BOOKING_TIMEZONE=Europe/London
BOOKING_OPEN_HOUR=9
BOOKING_CLOSE_HOUR=17
BOOKING_SLOT_MINUTES=45
BOOKING_WEEKDAYS=1,2,3,4,5
BOOKING_DEPOSIT_PENCE=5000
BOOKING_CURRENCY=gbp
BOOKING_HOLD_MINUTES=20
