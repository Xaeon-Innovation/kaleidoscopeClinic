rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Anonymous referral attachments (PDF / images only, size-capped).
    match /referral_uploads/{submissionId}/{fileName} {
      allow create: if request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
      allow read: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

