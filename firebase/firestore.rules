rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /team/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cases/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /leads/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /referrals/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Created/updated only by Firebase Admin (API / webhooks).
    match /appointments/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Admin-managed booking slots — public read so patients can see availability
    match /availableSlots/{docId} {
      allow read: if true;
      allow write: if false; // Written server-side via Admin SDK only
    }

    match /booking_holds/{docId} {
      allow read, write: if false;
    }
  }
}

